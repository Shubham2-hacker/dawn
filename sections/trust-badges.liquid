{{ 'section-trust-badges.css' | asset_url | stylesheet_tag }}

<div class="trust-badges color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="trust-badges__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="trust-badges__grid">
      {% for block in section.blocks %}
        <div class="trust-badge" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 100 }}"
              alt="{{ block.settings.title }}"
              loading="lazy"
              width="50"
              height="50">
          {% endif %}

          <div class="trust-badge__content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Trust Badges",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Why Shop With Us"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "background-1"
      }
    ],
    "blocks": [
      {
        "type": "badge",
        "name": "Badge",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "Icon"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Secure Payment"
          },
          {
            "type": "text",
            "id": "text",
            "label": "Description",
            "default": "100% secure checkout"
          }
        ]
      }
    ],
    "max_blocks": 6,
    "presets": [
      {
        "name": "Trust Badges",
        "blocks": [
          {
            "type": "badge"
          },
          {
            "type": "badge"
          },
          {
            "type": "badge"
          }
        ]
      }
    ]
  }
{% endschema %}

<style>
  .trust-badges {
    padding: 50px 0;
  }

  .trust-badges__heading {
    text-align: center;
    margin-bottom: 30px;
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .trust-badge {
    text-align: center;
    padding: 20px;
    border: 1px solid rgba(0, 0, 0, .08);
    border-radius: 12px;
  }

  .trust-badge img {
    display: block;
    margin: 0 auto 12px;
  }

  .trust-badge__content h3 {
    margin: 0 0 8px;
    font-size: 1.6rem;
  }

  .trust-badge__content p {
    margin: 0;
    opacity: 0.8;
  }
</style>
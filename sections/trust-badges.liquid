{% liquid
  assign cols = section.settings.columns
%}

<style>
  .trust-badges-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .trust-badges__wrapper-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .trust-badges__heading-{{ section.id }} {
    text-align: center;
    margin: 0 0 30px;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
  }

  .trust-badges__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ cols }}, 1fr);
    gap: 20px;
  }

  .trust-badge-card-{{ section.id }} {
    text-align: center;
    padding: 24px 16px;
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_bg }};
    border: 1px solid rgba(0, 0, 0, .08);
    transition: transform 0.25s ease;
  }

  .trust-badge-card-{{ section.id }}:hover {
    transform: translateY(-4px);
  }

  .trust-badge-icon-{{ section.id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 14px;
  }

  .trust-badge-icon-{{ section.id }}
  img
  , .trust-badge-icon-{{ section.id }}
  svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .trust-badge-title-{{ section.id }} {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .trust-badge-text-{{ section.id }} {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    opacity: .8;
  }

  @media screen and (max-width: 989px) {
    .trust-badges__grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .trust-badges__grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .trust-badges__heading-{{ section.id }} {
      font-size: calc({{ section.settings.heading_size }}px * 0.8);
    }
  }
</style>

<section class="trust-badges-{{ section.id }}">
  <div class="trust-badges__wrapper-{{ section.id }}">
    {% if section.settings.heading != blank %}
      <h2 class="trust-badges__heading-{{ section.id }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="trust-badges__grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="trust-badge-card-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="trust-badge-icon-{{ section.id }}">
            {% if block.settings.icon != blank %}
              {{ block.settings.icon
 | image_url: width: 120
 | image_tag: loading: 'lazy'
              }}
            {% else %}
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2">
                <path d="M12 2L4 5v6c0 5.5 3.8 10.7 8 12 4.2-1.3 8-6.5 8-12V5l-8-3z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            {% endif %}
          </div>

          {% if block.settings.title != blank %}
            <h3 class="trust-badge-title-{{ section.id }}">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="trust-badge-text-{{ section.id }}">
              {{ block.settings.text }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Trust Badges",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Why Shop With Us"
      },
      {
        "type": "range",
        "id": "columns",
        "label": "Desktop columns",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 4
      },
      {
        "type": "range",
        "id": "heading_size",
        "label": "Heading size",
        "min": 20,
        "max": 50,
        "step": 2,
        "default": 32
      },
      {
        "type": "color",
        "id": "card_bg",
        "label": "Card background",
        "default": "#f8f8f8"
      },
      {
        "type": "range",
        "id": "card_radius",
        "label": "Card radius",
        "min": 0,
        "max": 30,
        "step": 2,
        "default": 12
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Top padding",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 48
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom padding",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 48
      }
    ],
    "blocks": [
      {
        "type": "badge",
        "name": "Trust Badge",
        "settings": [
          {
            "type": "image_picker",
            "id": "icon",
            "label": "Icon"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Secure Payments"
          },
          {
            "type": "textarea",
            "id": "text",
            "label": "Description",
            "default": "100% safe and encrypted checkout."
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Trust Badges",
        "blocks": [
          {
            "type": "badge"
          },
          {
            "type": "badge"
          },
          {
            "type": "badge"
          },
          {
            "type": "badge"
          }
        ]
      }
    ]
  }
{% endschema %}
{{ 'css-header-campar.css' | asset_url | stylesheet_tag }}
{%- if section.settings.fullwidth -%}
  {%- assign container = 'container-full' -%}
{%- elsif section.settings.max_width != blank -%}
  {%- assign container = 'bwp-container' -%}
{%- else -%}
  {%- assign container = 'container' -%}
{%- endif -%}
{%- assign max_width = '' -%}
{%- if section.settings.fullwidth == blank and section.settings.max_width != blank -%}
  {%- assign width_container = section.settings.max_width | plus: 0 -%}
  {%- capture max_width -%}style="max-width: {{ section.settings.max_width }};"{%- endcapture -%}
{%- endif -%}
{% assign margin = section.settings.margin | split: '|' %}
{% assign padding = section.settings.padding | split: '|' %}

{%- if section.settings.show_campar -%}
  {%- style -%}
    {%- if margin[0] != blank or padding[0] != blank -%}
    	.bwp-header-campar{
    		{%- if margin[0] != blank -%}margin: {{ margin[0] }};{%- endif -%}
    		{%- if padding[0] != blank -%}padding:{{ padding[0] }};{%- endif -%}
    	}
    {%- endif -%}
    {%- if section.settings.bg_background -%}
    	.bwp-header-campar{
    		background:{{ section.settings.bg_background }};
    	}
    {%- endif -%}
    {%- if section.settings.marquee_content -%}
    	.bwp-header-campar li{
    		-webkit-animation-duration: {{ section.settings.marquee_time }}s;
    		animation-duration: {{ section.settings.marquee_time }}s;
    	}
    {%- endif -%}
    .bwp-header-campar a{
    	color:{{ section.settings.color_content }};
    	font-size: {{ section.settings.font_size }}px;
    	font-weight: {{ section.settings.font_weight }};
    }
    {%- if section.settings.color_span -%}
    	.bwp-header-campar a span{
    		color:{{ section.settings.color_span }};
    	}
    {%- endif -%}
    @media (max-width:1200px){
    	{%- if margin[1] != blank or padding[1] != blank -%}
    		.bwp-header-campar{
    			{%- if margin[1] != blank -%}margin: {{ margin[1] }};{%- endif -%}
    			{%- if padding[1] != blank -%}padding:{{ padding[1] }};{%- endif -%}
    		}
    	{%- endif -%}
    }
    @media (max-width:991px){
    	{%- if margin[2] != blank or padding[2] != blank -%}
    		.bwp-header-campar{
    			{%- if margin[2] != blank -%}margin: {{ margin[2] }};{%- endif -%}
    			{%- if padding[2] != blank -%}padding:{{ padding[2] }};{%- endif -%}
    		}
    	{%- endif -%}
    }
    @media (max-width:767px){
    	{%- if margin[3] != blank or padding[3] != blank -%}
    		.bwp-header-campar{
    			{%- if margin[3] != blank -%}margin: {{ margin[3] }};{%- endif -%}
    			{%- if padding[3] != blank -%}padding:{{ padding[3] }};{%- endif -%}
    		}
    	{%- endif -%}
    }
  {%- endstyle -%}
  <div
    data-section-id="{{ section.id }}"
    data-section-type="header-campar-section"
    class="bwp-header-campar{% unless section.settings.show_mobile %} hide_mobile{%- endunless -%}"
  >
    <div class="header-campbar">
      <div class="{{ container }}" {{ max_width }}>
        <div class="content-campbar">
          <div class="content-text">
            <div class="marquee_text_content">
              {%- if section.settings.marquee_content -%}
                <ul>
                  {% for i in (1..section.settings.marquee_loop) %}
                    <li>
                      <div class="announcement-wrapper">
                        <button class="announcement-btn prev-btn">‹</button>

                        <div class="announcement-slider">
                          {% for block in section.blocks %}
                            <div class="announcement-slide {% if forloop.first %}active{% endif %}">
                              <a href="{{ block.settings.link }}">
                                {{ block.settings.text }}
                              </a>
                            </div>
                          {% endfor %}
                        </div>

                        <button class="announcement-btn next-btn">›</button>
                      </div>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <div class="announcement-wrapper">
                  <button class="announcement-btn prev-btn">‹</button>

                  <div class="announcement-slider">
                    {% for block in section.blocks %}
                      <div class="announcement-slide {% if forloop.first %}active{% endif %}">
                        <a href="{{ block.settings.link }}">
                          {{ block.settings.text }}
                        </a>
                      </div>
                    {% endfor %}
                  </div>

                  <button class="announcement-btn next-btn">›</button>
                </div>
              {%- endif -%}
            </div>
          </div>
          {% comment %} <div class="close-campbar"></div> {% endcomment %}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<style>
  .announcement-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    width: fit-content;
    margin: 0 auto;
  }

  .announcement-btn {
    appearance: none;
    -webkit-appearance: none;
    background: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;

    width: 24px;
    height: 24px;
    padding: 0;
    margin: 0;

    display: flex;
    align-items: center;
    justify-content: center;

    color: #fff !important;
    font-size: 32px;
    font-weight: 300;
    line-height: 1;
    cursor: pointer;
  }

  .announcement-btn:hover {
    opacity: 0.7;
  }

  .announcement-btn:focus,
  .announcement-btn:active {
    background: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
  }

  .announcement-slider {
    position: relative;
    width: 450px;
    height: 24px;
    overflow: hidden;
  }

  .announcement-slide {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .announcement-slide.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* NEXT */
  .slide-in-right {
    visibility: visible !important;
    animation: slideInRight 0.5s forwards;
  }

  .slide-out-left {
    visibility: visible !important;
    animation: slideOutLeft 0.5s forwards;
  }

  /* PREVIOUS */
  .slide-in-left {
    visibility: visible !important;
    animation: slideInLeft 0.5s forwards;
  }

  .slide-out-right {
    visibility: visible !important;
    animation: slideOutRight 0.5s forwards;
  }

  @keyframes slideInRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes slideOutLeft {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(-100%);
      opacity: 0;
    }
  }

  @keyframes slideInLeft {
    from {
      transform: translateX(-100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes slideOutRight {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(100%);
      opacity: 0;
    }
  }
</style>

<script>
  window.addEventListener('load', function () {
    const slides = document.querySelectorAll('.announcement-slide');
    const nextBtn = document.querySelector('.next-btn');
    const prevBtn = document.querySelector('.prev-btn');

    let current = 0;

    slides[0].classList.add('active');

    function goToSlide(nextIndex, direction) {
      const currentSlide = slides[current];
      const nextSlide = slides[nextIndex];

      slides.forEach((slide) => {
        slide.classList.remove('slide-in-right', 'slide-out-left', 'slide-in-left', 'slide-out-right', 'active');
      });

      if (direction === 'next') {
        currentSlide.classList.add('slide-out-left');
        nextSlide.classList.add('slide-in-right');
      } else {
        currentSlide.classList.add('slide-out-right');
        nextSlide.classList.add('slide-in-left');
      }

      nextSlide.classList.add('active');
      current = nextIndex;
    }

    nextBtn.addEventListener('click', function () {
      goToSlide((current + 1) % slides.length, 'next');
    });

    prevBtn.addEventListener('click', function () {
      goToSlide((current - 1 + slides.length) % slides.length, 'prev');
    });

    setInterval(function () {
      goToSlide((current + 1) % slides.length, 'next');
    }, 4000);
  });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_campar",
      "label": "Show Campar",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout settings"
    },
    {
      "type": "text",
      "id": "max_width",
      "label": "Width container",
      "info": "Default: 1440px"
    },
    {
      "type": "checkbox",
      "id": "fullwidth",
      "label": "Fullwidth",
      "default": false
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Padding",
      "placeholder": "0px 0px 0px 0px",
      "info": "Screen: desktop | 1200px | 991px | 767px"
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Margin",
      "placeholder": "0px 0px 0px 0px",
      "info": "Screen: desktop | 1200px | 991px | 767px"
    },
    {
      "type": "color",
      "id": "bg_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Content settings"
    },
    {
      "type": "text",
      "id": "content_campar",
      "label": "Content",
      "default": "Summer sale discount <\span>off 60%<\/span>"
    },
    {
      "type": "url",
      "id": "url_campar",
      "label": "Url"
    },
    {
      "type": "color",
      "id": "color_content",
      "label": "Color text",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "color_span",
      "label": "Span tag color",
      "default": "#fff"
    },
    {
      "type": "number",
      "id": "font_size",
      "label": "Font size",
      "default": 18,
      "info": "px"
    },
    {
      "type": "text",
      "id": "font_weight",
      "label": "Font Weight",
      "default": "500"
    },
    {
      "type": "checkbox",
      "id": "marquee_content",
      "label": "Enable horizontal text animation",
      "default": true
    },
    {
      "type": "number",
      "id": "marquee_loop",
      "label": "number of repetitions of content",
      "default": 10
    },
    {
      "type": "number",
      "id": "marquee_time",
      "label": "Time animation",
      "default": 4,
      "info": "Units in seconds"
    },
    {
      "type": "checkbox",
      "id": "show_mobile",
      "label": "Show campar on mobile",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 5
}
{% endschema %}
